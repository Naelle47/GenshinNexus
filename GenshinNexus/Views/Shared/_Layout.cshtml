@{
    Layout = null;
    var title = ViewData["Title"] as string ?? "Genshin Nexus";
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <title>@title - Genshin Nexus</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Exo+2:wght@600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

    <!-- Font Awesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
          integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
          crossorigin="anonymous" referrerpolicy="no-referrer" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="layout">
        <!-- SIDEBAR -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <div class="sidebar-logo">
                    <span>Genshin Nexus</span>
                </div>

                <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Basculer thème clair/sombre">
                    <i class="fa-solid fa-sun icon-light"></i>
                    <i class="fa-solid fa-moon icon-dark"></i>
                </button>
            </div>

            <nav class="sidebar-nav">
                <a asp-controller="Home" asp-action="Index"
                   class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                    <i class="fa-solid fa-house"></i>
                    <span>Accueil</span>
                </a>
                <a asp-controller="Character" asp-action="Index"
                   class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Character" ? "active" : "")">
                    <i class="fa-solid fa-people-group"></i>
                    <span>Personnages</span>
                </a>
                <a asp-controller="Weapon" asp-action="Index"
                   class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Weapon" ? "active" : "")">
                    <i class="fa-solid fa-shield-halved"></i>
                    <span>Armes</span>
                </a>
                <a asp-controller="Build" asp-action="Index"
                   class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Build" ? "active" : "")">
                    <i class="fa-solid fa-wand-magic-sparkles"></i>
                    <span>Builds</span>
                </a>
            </nav>

            <div class="sidebar-footer">
                <button id="about-open" class="nav-item nav-button" type="button">
                    <i class="fa-solid fa-circle-info"></i>
                    <span>À propos du projet</span>
                </button>
            </div>
        </aside>

        <!-- CONTENU PRINCIPAL -->
        <main class="main">
            @RenderBody()
        </main>
    </div>

    <!-- MODALE À PROPOS -->
    <div id="about-modal" class="modal" aria-hidden="true">
        <div class="modal-backdrop"></div>
        <div class="modal-dialog" role="dialog" aria-modal="true" aria-labelledby="about-title">
            <button class="modal-close" id="about-close" aria-label="Fermer">
                <i class="fa-solid fa-xmark"></i>
            </button>
            <h2 id="about-title">À propos de Genshin Nexus</h2>
            <p>
                Genshin Nexus est une application 100% fan‑made créée par Naelle, joueuse de Genshin Impact
                depuis plus de cinq ans. L’objectif est de proposer un outil clair pour consulter les
                personnages, leurs builds et leurs synergies d’équipe, afin d’aider les joueurs à mieux
                comprendre le jeu et à progresser plus sereinement.
            </p>
            <p>
                Ce projet s’appuie sur les compétences acquises lors d’une formation en développement web :
                architecture en couches, base de données relationnelle et interface moderne en C#, ASP.NET
                Core MVC, PostgreSQL et Dapper. Genshin Nexus est ainsi à la fois un outil pratique pour la
                communauté et un projet vitrine présenté sur son profil GitHub.
            </p>
            <p>
                Naelle espère que Genshin Nexus pourra être utile à d’autres joueurs et qu’il contribuera à la richesse de la communauté francophone autour de Genshin Impact.
                N’hésitez pas à faire part de vos retours et suggestions pour améliorer l’application !
            </p>
        </div>
    </div>

    <script>
        // Thème
        const root = document.documentElement;
        const toggleBtn = document.getElementById('theme-toggle');
        const storedTheme = localStorage.getItem('theme');
        if (storedTheme === 'dark') root.classList.add('theme-dark');
        if (toggleBtn) {
            toggleBtn.addEventListener('click', () => {
                const isDark = root.classList.toggle('theme-dark');
                localStorage.setItem('theme', isDark ? 'dark' : 'light');
            });
        }

        // Modale À propos
        const aboutModal = document.getElementById('about-modal');
        const aboutOpen = document.getElementById('about-open');
        const aboutClose = document.getElementById('about-close');

        function openAbout() {
            aboutModal.classList.add('show');
            aboutModal.setAttribute('aria-hidden', 'false');
        }
        function closeAbout() {
            aboutModal.classList.remove('show');
            aboutModal.setAttribute('aria-hidden', 'true');
        }

        if (aboutOpen) aboutOpen.addEventListener('click', openAbout);
        if (aboutClose) aboutClose.addEventListener('click', closeAbout);
        if (aboutModal) {
            aboutModal.addEventListener('click', (e) => {
                if (e.target === aboutModal || e.target.classList.contains('modal-backdrop')) {
                    closeAbout();
                }
            });
        }
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                closeAbout();
            }
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
